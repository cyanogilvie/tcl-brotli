#else
#define Brotli_InitStubs(interp)	Tcl_PkgRequire((interp), "@PACKAGE_NAME@", "@PACKAGE_VERSION@", 0)
#endif

#include "brotliDecls.h"

EXTERN int Brotli_Init(Tcl_Interp *interp);

